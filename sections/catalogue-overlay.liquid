<div id="cinematic-overlay" class="fixed inset-0 z-[9999] hidden opacity-0 transition-opacity duration-800 h-[100dvh] w-[100vw] overflow-hidden" tabindex="0">
    <div id="cinematic-bg-layer" class="absolute inset-0 transition-colors duration-1000 bg-brand-dark">
        <div class="absolute inset-0 bg-gradient-to-br from-[#1A1208] via-[#0D0A05] to-[#0F0C06] opacity-80"></div>
        <div class="noise-overlay"></div>
    </div>
    
    <div class="cinematic-vignette" id="cinematic-vignette"></div>

    <!-- Top Navigation Layer -->
    <div class="absolute top-0 w-full z-50 p-6 md:p-10 flex justify-between items-start pointer-events-none">
        <button id="cinematic-back-btn" onclick="showCinematicGrid()" class="pointer-events-auto text-brand-cream hover:text-brand-gold transition-colors flex items-center gap-3 text-xs md:text-sm tracking-widest uppercase font-modern opacity-80 hover:opacity-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Collections
        </button>

        <button onclick="closeCinematicOverlay()" class="pointer-events-auto text-brand-cream hover:text-brand-gold transition-colors flex items-center gap-3 text-xs md:text-sm tracking-[0.2em] font-modern">
            <span class="hidden md:inline">EXIT</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-5 h-5 md:w-4 md:h-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
    </div>

    <!-- Product Slider View -->
    <div id="cinematic-slider-view" class="absolute inset-0 z-30 flex flex-col md:flex-row w-full h-full pt-28 pb-32 md:pt-32 md:pb-32">
        <!-- Visual Container (Left) -->
        <div id="cinematic-visual-box" class="w-full md:w-[45%] h-[35%] md:h-full flex flex-col items-center justify-center relative slide-content pt-16 md:pt-24 lg:pt-32 mt-4 md:mt-8">
            <div class="product-glow"></div>
            <div id="cinematic-icon" class="product-icon-container cinematic-icon-enter"><span id="c-icon">🪵</span></div>
        </div>

        <!-- Info Container (Right) -->
        <div id="cinematic-info-box" class="w-full md:w-[55%] h-[65%] md:h-full flex flex-col justify-start px-8 md:px-16 lg:px-24 slide-content relative overflow-y-auto no-scrollbar pb-8 md:pb-0 pt-24 md:pt-32 lg:pt-40">
            
            <div id="c-breadcrumb" class="stagger-text delay-0 text-brand-cream/60 text-[10px] md:text-xs tracking-[0.25em] uppercase font-modern mb-6 md:mb-10">
                <!-- Data -->
            </div>

            <div id="c-number" class="stagger-text delay-0 flex items-center gap-6 mb-7">
                <span class="text-brand-gold text-xs tracking-[0.3em] font-mono font-bold" id="c-index">01 / 06</span>
                <div class="h-[1px] w-16 bg-brand-gold/40"></div>
            </div>

            <h2 id="c-arabic" class="clip-reveal delay-1 font-arabic text-4xl md:text-5xl lg:text-[64px] text-brand-cream mt-8 pt-10 mb-0 leading-[1.4] h-auto shrink-0 pb-4">
                <!-- Data -->
            </h2>
            
            <h3 id="c-english" class="stagger-text delay-2 font-body italic text-2xl text-brand-gold font-light mt-3 mb-6 md:mb-8 border-b border-brand-gold/20 pb-1 inline-block w-fit">
                <!-- Data -->
            </h3>



            <p id="c-desc" class="stagger-text delay-4 font-body text-brand-cream/80 text-base md:text-[17px] leading-[1.8] md:leading-[1.9] max-w-[480px] mb-6 md:mb-8">
                <!-- Data -->
            </p>

            <div id="c-tags" class="stagger-text delay-5 flex flex-wrap gap-3 md:gap-4 mb-8 md:mb-10">
                <!-- Tags -->
            </div>

            <div id="c-price-box" class="stagger-text delay-5 flex flex-col mb-8 md:mb-12">
                <div id="c-price" class="font-mono text-xl md:text-2xl font-bold text-brand-gold"><!-- Data --></div>
                <div id="c-badge-container" class="mt-2 text-xs md:text-sm text-brand-cream/50 italic font-display">
                    <!-- Badge info -->
                </div>
            </div>

            <div id="c-action" class="stagger-text delay-5 w-auto inline-block mb-12 md:mb-0 shrink-0">
                <button id="cinematic-wa-btn" class="lux-btn flex items-center gap-4 py-3 md:py-3.5 px-8 md:px-10 rounded-sm cursor-pointer group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="lux-btn-content w-4 h-4 md:w-5 md:h-5 transition-transform duration-500 group-hover:scale-110" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/></svg>
                    <div class="lux-btn-content flex flex-col items-start text-left">
                        <span class="font-arabic-sans text-base md:text-lg font-bold leading-none mb-1.5 group-hover:text-brand-dark">اطلب عبر واتساب</span>
                        <span class="font-modern text-[8px] md:text-[9px] uppercase tracking-[0.25em] opacity-80 group-hover:opacity-100 transition-opacity">Order via WhatsApp</span>
                    </div>
                </button>
            </div>

        </div>

        <!-- Navigation Layer (Bottom) -->
        <div class="absolute bottom-6 md:bottom-10 left-0 right-0 z-50 flex items-center justify-center gap-8 md:gap-12 pointer-events-none">
            <button onclick="prevCinematicSlide()" class="pointer-events-auto text-brand-gold hover:text-brand-cream transition-colors p-2 hidden md:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            
            <div id="c-dots" class="pointer-events-auto flex gap-4 md:gap-5 items-center">
                <!-- Dots generated via JS -->
            </div>

            <button onclick="nextCinematicSlide()" class="pointer-events-auto text-brand-gold hover:text-brand-cream transition-colors p-2 hidden md:block">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
        </div>
    </div>

    <!-- Collection Grid View (Secondary Overlay) -->
    <div id="cinematic-grid-view" class="absolute inset-0 z-40 bg-brand-dark hidden items-center justify-center overflow-y-auto w-full h-full py-24">
        <div class="noise-overlay"></div>
        <div class="relative z-10 w-full max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 id="grid-title-ar" class="font-arabic text-4xl md:text-5xl text-brand-cream mb-4">--</h2>
                <h3 id="grid-title-en" class="font-display italic text-xl text-brand-gold">--</h3>
            </div>
            
            <div id="c-grid-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
                <!-- Cards generated via JS -->
            </div>
        </div>
    </div>

</div>

{% schema %}
{
  "name": "Cinematic Overlay",
  "settings": [],
  "presets": [
    {
      "name": "Cinematic Overlay"
    }
  ]
}
{% endschema %}
